# Backend Environment Variables
# Copy this file to .env and update the values as needed

# Server Port
PORT=80

# Allowed CORS Origins (comma-separated for multiple origins)
# Development: http://localhost:3000
# Production: https://aicte-snowy.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,https://aicte-snowy.vercel.app

# Worker Pool Size (concurrent validators)
WORKER_COUNT=10
